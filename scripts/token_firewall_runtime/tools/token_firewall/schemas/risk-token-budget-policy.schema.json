{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "token-firewall/risk-token-budget-policy@0.1",
  "title": "Token Firewall Risk-tier Token Budget Policy",
  "type": "object",
  "required": ["schema", "object_id", "revision", "created_at", "content_sha256", "tiers"],
  "properties": {
    "schema": {"const": "token-firewall/risk-token-budget-policy@0.1"},
    "object_id": {"type": "string", "pattern": "^budget_[A-Za-z0-9_.-]+$"},
    "revision": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "content_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "tiers": {
      "type": "object",
      "required": ["low", "medium", "high", "critical"],
      "properties": {
        "low": {"$ref": "#/$defs/tier"}, "medium": {"$ref": "#/$defs/tier"},
        "high": {"$ref": "#/$defs/tier"}, "critical": {"$ref": "#/$defs/tier"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "tier": {
      "type": "object",
      "required": ["required_review", "planning_sol_max", "review_sol_max", "total_sol_max", "minimum_sol_savings_percent", "max_rework_rounds"],
      "properties": {
        "required_review": {"enum": ["m3-then-sol", "terra-then-sol", "sol-deep-review"]},
        "planning_sol_max": {"type": "integer", "minimum": 0},
        "review_sol_max": {"type": "integer", "minimum": 1},
        "total_sol_max": {"type": "integer", "minimum": 1},
        "minimum_sol_savings_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "max_rework_rounds": {"type": "integer", "minimum": 0, "maximum": 10}
      },
      "additionalProperties": false
    }
  }
}
