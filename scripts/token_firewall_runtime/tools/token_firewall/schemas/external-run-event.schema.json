{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "token-firewall/external-run-event@0.1",
  "title": "Token Firewall External Run Event",
  "type": "object",
  "required": [
    "schema", "event_id", "run_id", "mission_id", "task_id", "stage",
    "runtime", "model", "session_id", "sequence", "at", "kind", "source", "summary"
  ],
  "properties": {
    "schema": {"const": "token-firewall/external-run-event@0.1"},
    "event_id": {"type": "string", "pattern": "^xevt_[A-Za-z0-9_.-]+$"},
    "run_id": {"type": "string", "minLength": 1},
    "mission_id": {"type": ["string", "null"]},
    "task_id": {"type": "string", "minLength": 1},
    "stage": {"enum": ["worker", "verifier", "deputy", "reviewer", "evaluator"]},
    "runtime": {"type": "string", "minLength": 1},
    "model": {"type": ["string", "null"]},
    "session_id": {"type": ["string", "null"]},
    "sequence": {"type": "integer", "minimum": 1},
    "at": {"type": "string", "format": "date-time"},
    "kind": {
      "enum": [
        "run.dispatched", "run.acknowledged", "run.activity", "run.idle",
        "run.stalled", "run.blocked", "run.recovered", "run.usage_updated",
        "run.delivery_received", "run.snapshot_frozen", "run.completed",
        "run.failed", "run.timed_out", "run.cancelled"
      ]
    },
    "source": {"enum": ["adapter", "process", "git", "broker", "watchdog", "recovery"]},
    "summary": {"type": "string", "minLength": 1},
    "native_status": {"type": "string", "minLength": 1},
    "payload_ref": {"type": "string", "minLength": 1},
    "payload_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "usage": {
      "type": "object",
      "required": [
        "input_tokens", "output_tokens", "reasoning_tokens", "cache_read_tokens",
        "cache_write_tokens", "total_tokens", "native_total_tokens", "source", "complete"
      ],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_tokens": {"type": "integer", "minimum": 0},
        "cache_read_tokens": {"type": "integer", "minimum": 0},
        "cache_write_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "native_total_tokens": {"type": "integer", "minimum": 0},
        "source": {"type": "string", "minLength": 1},
        "complete": {"type": "boolean"},
        "cost_usd": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "delivery": {
      "type": "object",
      "required": ["commit", "changed_files", "additions", "deletions"],
      "properties": {
        "commit": {"type": ["string", "null"]},
        "changed_files": {"type": "integer", "minimum": 0},
        "additions": {"type": "integer", "minimum": 0},
        "deletions": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
