{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "token-firewall/evaluation-lab-manifest@0.1",
  "title": "Token Firewall Evaluation Lab Manifest",
  "type": "object",
  "required": [
    "schema", "object_id", "content_sha256", "lab_id", "created_at",
    "protocol_ref", "protocol_sha256", "pairs", "dataset_sha256"
  ],
  "properties": {
    "schema": {"const": "token-firewall/evaluation-lab-manifest@0.1"},
    "object_id": {"type": "string", "pattern": "^lab_[A-Za-z0-9_.-]+$"},
    "content_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "lab_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "protocol_ref": {"const": "protocol.json"},
    "protocol_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "pairs": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["pair_id", "path", "sha256"],
        "properties": {
          "pair_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^pairs/[A-Za-z0-9_.-]+\\.json$"},
          "sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "dataset_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"}
  },
  "additionalProperties": false
}
