{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "token-firewall/delivery-manifest@0.1",
  "title": "Token Firewall Delivery Manifest",
  "type": "object",
  "required": [
    "schema", "object_id", "mission_id", "revision", "created_at", "created_by",
    "content_sha256", "task_id", "attempt", "base_commit", "head_commit", "patch",
    "changed_files", "spec_results", "tests", "deviations", "uncertainties",
    "failed_attempts_summary", "artifacts", "usage", "worker_proposal"
  ],
  "properties": {
    "schema": {"const": "token-firewall/delivery-manifest@0.1"},
    "object_id": {"type": "string", "pattern": "^dm_[A-Za-z0-9_.-]+$"},
    "mission_id": {"type": "string", "pattern": "^msn_[A-Za-z0-9_.-]+$"},
    "revision": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "created_by": {"$ref": "#/$defs/creator"},
    "supersedes": {"type": ["string", "null"]},
    "content_sha256": {"$ref": "#/$defs/sha256"},
    "task_id": {"type": "string", "pattern": "^T-[A-Za-z0-9_.-]+$"},
    "attempt": {"type": "integer", "minimum": 1},
    "base_commit": {"$ref": "#/$defs/commit"},
    "head_commit": {"$ref": "#/$defs/commit"},
    "patch": {"$ref": "#/$defs/evidence_ref"},
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object", "required": ["path", "status", "additions", "deletions"],
        "properties": {
          "path": {"$ref": "#/$defs/repo_path"},
          "status": {"enum": ["added", "modified", "deleted", "renamed", "copied", "type-changed"]},
          "additions": {"type": "integer", "minimum": 0},
          "deletions": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "spec_results": {
      "type": "array",
      "items": {
        "type": "object", "required": ["spec_id", "status", "evidence_ref"],
        "properties": {
          "spec_id": {"type": "string", "pattern": "^SPEC-[A-Za-z0-9_.-]+$"},
          "status": {"enum": ["pass", "fail", "blocked"]},
          "evidence_ref": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object", "required": ["command", "exit_code", "evidence_ref"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "exit_code": {"type": "integer"},
          "evidence_ref": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "deviations": {"type": "array", "items": {"type": "string"}},
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "failed_attempts_summary": {"type": "array", "items": {"type": "string"}},
    "artifacts": {"type": "array", "items": {"$ref": "#/$defs/evidence_ref"}},
    "usage": {
      "type": "object", "required": [
        "model", "input_tokens", "output_tokens", "cache_read_tokens", "total_tokens",
        "native_total_tokens", "cost_usd", "usage_source", "usage_complete"
      ],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "cache_read_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "native_total_tokens": {"type": "integer", "minimum": 0},
        "cost_usd": {"type": "number", "minimum": 0},
        "usage_source": {"type": "string", "minLength": 1},
        "usage_complete": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "worker_proposal": {"const": "DELIVERED"}
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "commit": {"type": "string", "pattern": "^[a-fA-F0-9]{7,64}$"},
    "repo_path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "creator": {
      "type": "object", "required": ["role", "runtime", "model", "session_id"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "runtime": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "session_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object", "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": {"$ref": "#/$defs/repo_path"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "bytes": {"type": "integer", "minimum": 0},
        "mime_type": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
