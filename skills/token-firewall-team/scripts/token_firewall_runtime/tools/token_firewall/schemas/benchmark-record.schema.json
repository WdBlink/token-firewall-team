{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "token-firewall/benchmark-record@0.1",
  "title": "Token Firewall Benchmark Record",
  "type": "object",
  "required": [
    "schema", "content_sha256", "candidate_id", "run_id", "group_id", "task_revision", "base_sha",
    "mission_content_sha256", "task_content_sha256",
    "mission_id", "task_id", "started_at", "finished_at", "elapsed_seconds",
    "status", "commit_range", "diff", "public_gate", "hidden_evaluation",
    "review", "stages", "scope_violations", "artifacts"
  ],
  "properties": {
    "schema": {"const": "token-firewall/benchmark-record@0.1"},
    "content_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_id": {"type": "string", "pattern": "^cand_[A-Za-z0-9_.-]+$"},
    "run_id": {"type": "string", "pattern": "^run_[A-Za-z0-9_.-]+$"},
    "group_id": {"enum": ["A", "B", "C", "D", "E"]},
    "task_revision": {"type": "integer", "minimum": 1},
    "base_sha": {"$ref": "#/$defs/commit"},
    "mission_content_sha256": {"$ref": "#/$defs/sha256"},
    "task_content_sha256": {"$ref": "#/$defs/sha256"},
    "mission_id": {"type": "string", "pattern": "^msn_[A-Za-z0-9_.-]+$"},
    "task_id": {"type": "string", "pattern": "^T-[A-Za-z0-9_.-]+$"},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "elapsed_seconds": {"type": "number", "minimum": 0},
    "status": {"enum": [
      "MODEL_STAGES_COMPLETE", "COMPLETE", "WORKER_FAILED", "VERIFIER_FAILED",
      "REVIEW_FAILED", "HIDDEN_EVAL_ERROR", "HARNESS_FAILED"
    ]},
    "commit_range": {
      "type": "object",
      "required": ["base", "head"],
      "properties": {
        "base": {"$ref": "#/$defs/commit"},
        "head": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{7,64}$"}
      },
      "additionalProperties": false
    },
    "diff": {
      "type": "object",
      "required": ["files", "additions", "deletions"],
      "properties": {
        "files": {"type": "integer", "minimum": 0},
        "additions": {"type": "integer", "minimum": 0},
        "deletions": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "public_gate": {
      "type": "object",
      "required": ["status", "finding_codes"],
      "properties": {
        "status": {"enum": ["pass", "fail", "not_run"]},
        "finding_codes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "hidden_evaluation": {
      "type": "object",
      "required": [
        "test_id", "suite_sha256", "status", "exit_code", "duration_ms", "stdout_sha256",
        "stderr_sha256", "stdout_bytes", "stderr_bytes", "assertions_disclosed"
      ],
      "properties": {
        "test_id": {"type": "string", "minLength": 1},
        "suite_sha256": {"$ref": "#/$defs/sha256"},
        "status": {"enum": ["pass", "fail", "not_run"]},
        "exit_code": {"type": ["integer", "null"]},
        "duration_ms": {"type": "integer", "minimum": 0},
        "stdout_sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
        "stderr_sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
        "stdout_bytes": {"type": "integer", "minimum": 0},
        "stderr_bytes": {"type": "integer", "minimum": 0},
        "assertions_disclosed": {"const": false}
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": [
        "verdict", "findings", "high_critical_findings", "coverage_gaps",
        "requested_context", "rubric_revision", "prompt_template_sha256"
      ],
      "properties": {
        "verdict": {"enum": ["PASS", "REWORK", "ESCALATE", "not_run"]},
        "findings": {"type": "integer", "minimum": 0},
        "high_critical_findings": {"type": "integer", "minimum": 0},
        "coverage_gaps": {"type": "integer", "minimum": 0},
        "requested_context": {"type": "integer", "minimum": 0},
        "rubric_revision": {"type": "string", "minLength": 1},
        "prompt_template_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "stages": {
      "type": "object",
      "required": ["worker", "verifier", "reviewer"],
      "properties": {
        "worker": {"$ref": "#/$defs/stage"},
        "verifier": {"anyOf": [{"$ref": "#/$defs/stage"}, {"type": "null"}]},
        "reviewer": {"anyOf": [{"$ref": "#/$defs/stage"}, {"type": "null"}]}
      },
      "additionalProperties": false
    },
    "scope_violations": {"type": "array", "items": {"type": "string"}},
    "artifacts": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "commit": {"type": "string", "pattern": "^[a-fA-F0-9]{7,64}$"},
    "usage": {
      "type": "object",
      "required": [
        "input_tokens", "output_tokens", "reasoning_tokens", "cache_read_tokens",
        "cache_write_tokens", "total_tokens", "native_total_tokens", "source", "complete"
      ],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_tokens": {"type": "integer", "minimum": 0},
        "cache_read_tokens": {"type": "integer", "minimum": 0},
        "cache_write_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "native_total_tokens": {"type": "integer", "minimum": 0},
        "source": {"type": "string", "minLength": 1},
        "complete": {"type": "boolean"},
        "cost_usd": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "stage": {
      "type": "object",
      "required": [
        "role", "runtime", "runtime_version", "model_requested", "model_effective",
        "model_effective_verified", "counts_as_sol", "session_id", "status", "usage"
      ],
      "properties": {
        "role": {"enum": ["worker", "verifier", "deputy", "reviewer"]},
        "runtime": {"type": "string", "minLength": 1},
        "runtime_version": {"type": "string", "minLength": 1},
        "model_requested": {"type": "string", "minLength": 1},
        "model_effective": {"type": "string", "minLength": 1},
        "model_effective_verified": {"type": "boolean"},
        "counts_as_sol": {"type": "boolean"},
        "session_id": {"type": ["string", "null"]},
        "status": {"type": "string", "minLength": 1},
        "usage": {"$ref": "#/$defs/usage"}
      },
      "additionalProperties": false
    }
  }
}
